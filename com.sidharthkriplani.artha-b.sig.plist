<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.sidharthkriplani.artha-b.sig</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/ASUS/Documents/GitHub/artha-b.sig/run_daily.sh</string>
    </array>

    <!-- Runs every day at 08:00 AM -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/ASUS/Documents/GitHub/artha-b.sig/data/launchd.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/ASUS/Documents/GitHub/artha-b.sig/data/launchd.log</string>

    <!-- Run missed jobs when machine wakes up -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
